<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Wemert Group Realty</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #f4f6f9;
}
header {
  background: #0a2a66;
  color: white;
  padding: 20px;
  text-align: center;
}
.filters {
  padding: 15px;
  background: white;
}
.filters select, .filters button {
  width: 100%;
  padding: 12px;
  margin-top: 10px;
  font-size: 16px;
}
.listings {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px,1fr));
  gap: 15px;
  padding: 15px;
}
.card {
  background: white;
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}
.card img {
  width: 100%;
  height: 200px;
  object-fit: cover;
}
.card-content {
  padding: 12px;
}
.card-content h3 {
  margin: 5px 0;
}
.icons {
  font-size: 14px;
  color: #555;
}
.card button {
  width: 100%;
  padding: 10px;
  margin-top: 8px;
  border: none;
  background: #0a2a66;
  color: white;
  font-size: 16px;
  border-radius: 6px;
}
footer {
  background: #0a2a66;
  color: white;
  text-align: center;
  padding: 15px;
}
</style>
</head>

<body>

<header>
<h1>Wemert Group Realty</h1>
<p>Affordable Homes Across Orlando, Florida</p>
</header>

<div class="filters">
<select id="priceFilter">
<option value="">Max Price</option>
<option value="200000">$200,000</option>
<option value="250000">$250,000</option>
<option value="300000">$300,000</option>
<option value="350000">$350,000</option>
</select>

<select id="bedFilter">
<option value="">Min Bedrooms</option>
<option value="2">2+</option>
<option value="3">3+</option>
<option value="4">4+</option>
</select>

<button onclick="filterHomes()">Search Homes</button>
</div>

<div class="listings" id="listings"></div>

<footer>
<p><strong>Wemert Group Realty</strong></p>
<p>📧 GRealtyGroup1@gmail.com</p>
<p>📞 407-435-5072</p>
</footer>

<script>
const homes = [
{img:"https://images.unsplash.com/photo-1570129477492-45c003edd2be",price:185000,bed:2,loc:"Lake Nona"},
{img:"https://images.unsplash.com/photo-1568605114967-8130f3a36994",price:198000,bed:3,loc:"Winter Park"},
{img:"https://images.unsplash.com/photo-1600585154340-be6161a56a0c",price:215000,bed:3,loc:"Kissimmee"},
{img:"https://images.unsplash.com/photo-1580587771525-78b9dba3b914",price:225000,bed:2,loc:"Altamonte Springs"},
{img:"https://images.unsplash.com/photo-1592595896551-12b371d546d5",price:235000,bed:3,loc:"Oviedo"},
{img:"https://images.unsplash.com/photo-1598228723793-52759bba239c",price:245000,bed:4,loc:"Apopka"},
{img:"https://images.unsplash.com/photo-1576941089067-2de3c901e126",price:255000,bed:3,loc:"Casselberry"},
{img:"https://images.unsplash.com/photo-1600047509807-ba8f99d2cdde",price:265000,bed:4,loc:"Sanford"},
{img:"https://images.unsplash.com/photo-1572120360610-d971b9d7767c",price:275000,bed:3,loc:"Ocoee"},
{img:"https://images.unsplash.com/photo-1507089947368-19c1da9775ae",price:285000,bed:4,loc:"Clermont"},
{img:"https://images.unsplash.com/photo-1554995207-c18c203602cb",price:295000,bed:3,loc:"Maitland"},
{img:"https://images.unsplash.com/photo-1582268611958-ebfd161ef9cf",price:305000,bed:4,loc:"Dr. Phillips"},
{img:"https://images.unsplash.com/photo-1597047084897-51e81819a499",price:315000,bed:4,loc:"Union Park"},
{img:"https://images.unsplash.com/photo-1564013799919-ab600027ffc6",price:325000,bed:5,loc:"Pine Hills"},
{img:"https://images.unsplash.com/photo-1605276373954-0c4a0dac5b12",price:335000,bed:4,loc:"Belle Isle"},
{img:"https://images.unsplash.com/photo-1560185127-6a8c97b5cc21",price:345000,bed:5,loc:"Edgewood"},
{img:"https://images.unsplash.com/photo-1588854337118-1c3a29b6bb65",price:355000,bed:4,loc:"Winter Garden"},
{img:"https://images.unsplash.com/photo-1600566753376-12c8ab7fb75b",price:365000,bed:5,loc:"Windermere"},
{img:"https://images.unsplash.com/photo-1595526114035-0d45ed16cfbf",price:375000,bed:4,loc:"Horizon West"},
{img:"https://images.unsplash.com/photo-1554435493-93422e8220c8",price:385000,bed:5,loc:"Lake Mary"},
];

function render(list){
const box=document.getElementById("listings");
box.innerHTML="";
list.forEach(h=>{
box.innerHTML+=`
<div class="card">
<img src="${h.img}">
<div class="card-content">
<h3>$${h.price.toLocaleString()}</h3>
<p>${h.loc}, Orlando FL</p>
<p class="icons">🛏 ${h.bed} Bedrooms</p>
<button onclick="email('${h.loc}')">View Details / Schedule Visit</button>
</div>
</div>`;
});
}

function filterHomes(){
const p=document.getElementById("priceFilter").value;
const b=document.getElementById("bedFilter").value;
render(homes.filter(h=>(!p||h.price<=p)&&(!b||h.bed>=b)));
}

function email(loc){
window.location.href=`mailto:GRealtyGroup1@gmail.com?subject=House Inquiry - ${loc}`;
}

render(homes);
</script>

</body>
</html>
